# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# ─────────────────────────────────────────
# Database (FIXED)
# ─────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=crm_db

DATABASE_URL=postgresql://crm_user:strongpassword123@postgres:5432/crm_db?schema=public

# ─────────────────────────────────────────
# Redis (FIXED)
# ─────────────────────────────────────────
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379

# ─────────────────────────────────────────
# MongoDB (FIXED)
# ─────────────────────────────────────────
MONGO_USER=crm_mongo
MONGO_PASSWORD=strongmongo123
MONGO_URI=mongodb://crm_mongo:strongmongo123@mongodb:27017/crm_logs

# ─────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────
JWT_SECRET=super-secure-prod-jwt-key-CHANGE
JWT_REFRESH_SECRET=super-secure-refresh-key-CHANGE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# Email
# ─────────────────────────────────────────
SENDGRID_API_KEY=your-real-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=CRM Platform

# ─────────────────────────────────────────
# Twilio
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-real
TWILIO_AUTH_TOKEN=your-real
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=live_key
STRIPE_PUBLISHABLE_KEY=live_key
STRIPE_WEBHOOK_SECRET=live_secret

# ─────────────────────────────────────────
# PayPal
# ─────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your-real
PAYPAL_CLIENT_SECRET=your-real

# ─────────────────────────────────────────
# AI (optional)
# ─────────────────────────────────────────
OPENAI_API_KEY=your-real

# ─────────────────────────────────────────
# Blockchain (optional)
# ─────────────────────────────────────────
BLOCKCHAIN_RPC_URL=your-real
BLOCKCHAIN_PRIVATE_KEY=your-real
BLOCKCHAIN_CONTRACT_ADDR=your-real

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=info